flowchart LR
    subgraph UI[表现层]
        D[医生端 React]
        P[患者端 React]
    end

    subgraph Backend[业务层 FastAPI]
        AUTH[认证鉴权]
        UPLOAD[CT登记与预览]
        AIJOB[AI任务编排]
        REPORT[报告与随访]
        CHAT[患者问答]
    end

    subgraph Engine[算法层 AI Engine]
        ADAPTER[Detector Adapter]
        MOCK[Mock Detector]
        MONAI[MONAI Bundle Detector]
    end

    subgraph Data[数据层]
        DB[(SQLite)]
        CT[本地CT文件]
        LLM[外部大模型接口 可选]
    end

    D --> AUTH
    D --> UPLOAD
    D --> AIJOB
    D --> REPORT
    P --> REPORT
    P --> CHAT

    AUTH --> DB
    UPLOAD --> DB
    REPORT --> DB
    AIJOB --> DB
    CHAT --> DB

    UPLOAD --> CT
    AIJOB --> ADAPTER
    ADAPTER --> MOCK
    ADAPTER --> MONAI
    MONAI --> CT
    CHAT --> LLM
